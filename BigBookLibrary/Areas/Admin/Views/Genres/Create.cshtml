@model BigBookLibrary.Areas.Admin.ViewModels.Genres.GenreFormModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    ViewData["Title"] = "Create Genre";
}

<h2 class="mt-4">Create Genre</h2>

<form asp-action="Create" method="post" class="mt-3">

    <partial name="_GenreFormPartial" model="Model" />

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-area="Admin" asp-controller="Genres" asp-action="Index" class="btn btn-secondary ms-2">
        Back to List
    </a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
