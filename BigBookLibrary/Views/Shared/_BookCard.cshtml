@using BigBookLibrary.ViewModels.Books
@model BookCardViewModel

<div class="col-md-3 col-sm-6 mb-4">
    <div class="card shadow-sm h-100 book-card">

        <img src="@Model.CoverImagePath"
             alt="@Model.Title cover"
             class="book-card-cover" />

        <div class="card-body text-center">

            <h5 class="book-card-title">@Model.Title</h5>

            <p class="book-card-meta">
                <strong>Author:</strong> @Model.AuthorName <br />
                <strong>Genre:</strong> @Model.GenreName
            </p>

            <a href="@Model.DetailsUrl"
               class="btn btn-outline-primary w-100 mt-2">
                Details
            </a>

        </div>
    </div>
</div>
