@using BigBookLibrary.ViewModels.Books
@model IEnumerable<BookCardViewModel>

<h2 class="mb-4 text-center">
    Books by @ViewBag.AuthorName (@Model.Count())
</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title text-center mb-3">Biography</h5>
        <p class="card-text text-center">
            @Model.First().AuthorBiography
        </p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        This author has no books yet.
    </div>
}
else
{
    <div class="row">
        @foreach (var book in Model)
        {
            <partial name="_BookCard" model="book" />
        }
    </div>
}
