@model IEnumerable<BigBookLibrary.Models.Book>

<h2 class="mb-4">Search Results</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No books found.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var book in Model)
        {
            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm h-100">
                    <img src="@book.CoverImagePath" class="card-img-top" style="height: 300px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@book.Title</h5>
                        <p class="text-muted mb-1"><strong>Author:</strong> @book.Author.Name</p>
                        <p class="text-muted mb-3"><strong>Genre:</strong> @book.Genre.Name</p>

                        <a href="/Books/Details/@book.Id" class="btn btn-primary mt-auto">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
