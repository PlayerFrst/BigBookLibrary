@using BigBookLibrary.Extensions
@model BigBookLibrary.ViewModels.Books.BookDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">

    <div class="row">
        <!-- LEFT: Book Cover -->
        <div class="col-md-4">
            <div class="book-cover-wrapper">
                <img src="@Model.CoverImagePath"
                     class="book-cover-img"
                     alt="Book Cover" />
            </div>
        </div>


        <!-- RIGHT: Book Info -->
        <div class="col-md-8">
            <h1 class="book-title">@Model.Title</h1>

            <div class="card shadow-sm mb-4 book-info-card">
                <div class="card-body">

                    <p class="mb-1 book-meta">
                        <strong>Author:</strong>
                        <span data-bs-toggle="tooltip"
                              data-bs-placement="right"
                              title="@Model.AuthorBiography"
                              style="cursor: help; text-decoration: underline dotted;">
                            @Model.AuthorName
                        </span>
                    </p>


                    <p class="mb-1 book-meta">
                        <strong>Genre:</strong> @Model.GenreName
                    </p>

                    <p class="mb-1 book-meta">
                        <strong>ISBN:</strong> @Model.ISBN
                    </p>

                    <p class="mb-3 book-meta">
                        <strong>Available copies:</strong>
                        <span class="badge bg-@(Model.CopiesAvailable > 0 ? "success" : "danger")">
                            @Model.CopiesAvailable
                        </span>
                    </p>

                    <p class="book-description">@Model.Description</p>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (Model.CopiesAvailable > 0)
                        {
                            <a asp-controller="Borrowing"
                               asp-action="Rent"
                               asp-route-id="@Model.Id"
                               class="btn btn-primary">
                                Borrow
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>
                                Not available
                            </button>
                        }
                    }

                    @if (TempData["BorrowSuccess"] != null)
                    {
                        <div class="alert alert-success mt-3">
                            @TempData["BorrowSuccess"]
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger mt-3">
                            @TempData["Error"]
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <!-- REVIEWS SECTION -->
    <h3 class="mb-3">Reviews</h3>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="card shadow-sm mb-4 review-form-card">
            <div class="card-body">
                <h5 class="mb-3">Write a Review</h5>

                <form method="post" asp-controller="Review" asp-action="Add" asp-route-bookId="@Model.Id">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ReviewForm.Rating" class="form-label"></label>
                        <select asp-for="ReviewForm.Rating" class="form-select">
                            <option value="">Select rating</option>
                            <option value="5">5 - Excellent</option>
                            <option value="4">4 - Very Good</option>
                            <option value="3">3 - Good</option>
                            <option value="2">2 - Poor</option>
                            <option value="1">1 - Bad</option>
                        </select>
                        <span asp-validation-for="ReviewForm.Rating" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReviewForm.Comment" class="form-label"></label>
                        <textarea asp-for="ReviewForm.Comment" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="ReviewForm.Comment" class="text-danger"></span>
                    </div>

                    <button class="btn btn-success">Submit Review</button>
                </form>
            </div>
        </div>
    }

    @if (Model.Reviews.Any())
    {
        @foreach (var review in Model.Reviews)
        {
            <div class="card shadow-sm mb-3 review-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <strong class="review-author">@review.UserName</strong>
                        <span class="review-rating">@review.Rating ★</span>
                    </div>

                    <p class="mt-2">@review.Comment</p>
                    <small class="review-date">@review.CreatedOn.ToShortDateString()</small>

                    @if (User.Identity.IsAuthenticated &&
                                (review.UserId == User.GetId() || User.IsInRole("Administrator")))
                    {
                        <form method="post" asp-controller="Review" asp-action="Delete"
                              asp-route-id="@review.Id" asp-route-bookId="@Model.Id" class="mt-2">
                            <button class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No reviews yet.</p>
    }

</div>
