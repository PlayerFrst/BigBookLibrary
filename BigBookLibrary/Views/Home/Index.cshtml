@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&display=swap" rel="stylesheet">

<style>
    .fun-text {
        font-family: 'Fredoka', sans-serif;
        font-size: 1.6rem;
        color: #ff5722;
        font-weight: 600;
    }

    .arrow-to-nav {
        position: fixed;
        top: 15px; 
        right: 160px; 
        animation: arrowBounce 1.2s infinite;
        z-index: 9999;
    }

    {
        transform: translateY(0) rotate(-45deg);
    }

    50% {
        transform: translateY(-8px) rotate(-45deg);
    }

    100% {
        transform: translateY(0) rotate(-45deg);
    }

    }

    .arrow-svg {
        width: 80px;
        height: 80px;
        stroke: #ff5722;
    }

    .hint-box {
        margin-top: 150px;
        padding: 25px;
        border-radius: 12px;
        background: #fff7f2;
        border: 2px dashed #ff5722;
        display: inline-block;
    }
</style>

<div class="text-center">

    @if (!SignInManager.IsSignedIn(User))
    {

        <div class="arrow-to-nav">
            <svg class="arrow-svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="M13 5l7 7-7 7"></path>
            </svg>
        </div>

        <h1 class="display-4 fun-text">Welcome to BigBookLibrary!</h1>

        <div class="container mt-5">
            <div class="p-4 mb-4 bg-light rounded-3 shadow-sm">
                <h2 class="fw-bold">Здравейте и добре дошли!</h2>
                <p class="mt-3">
                    Това е моят проект за курса, който изпълнява всички поставени изисквания.
                    Сайтът е разделен на потребителска и администраторска зона, като основната
                    функционалност е реализирана в админ панела.
                </p>
                <p>
                    Можете да влезете с администраторския акаунт чрез бутона горе вдясно.
                </p>
            </div>
            <div class="alert alert-warning mt-3">
                Настоящите визуални насоки и помощни елементи са добавени единствено с цел
                по-лесна ориентация по време на проверката. В бъдещи версии те ще бъдат
                премахнати, тъй като не са част от финалния дизайн.
            </div>

        </div>

    }
    else
    {
        <h1 class="display-4 fun-text">Welcome back, mighty librarian! 📚</h1>

        <div class="alert alert-info mt-4">
            Вече сте влезли успешно в администраторска роля. В горната навигация е активен бутонът
            <strong>Admin Panel</strong>, откъдето можете да управлявате съдържанието на сайта.
        </div>

    }
</div>
