@model IEnumerable<BigBookLibrary.Areas.Admin.ViewModels.Authors.AuthorViewModel>


@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Authors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Authors</h2>

    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Create Author
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No authors found.
    </div>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th style="width: 180px;" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var author in Model)
            {
                <tr>
                    <td>@author.Name</td>
                    <td class="text-end">

                        <a class="btn btn-warning btn-sm me-2"
                           href="/Admin/Authors/Edit/@author.Id">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>

                        <button class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@author.Id"
                                data-name="@author.Name">
                            <i class="bi bi-trash"></i> Delete
                        </button>

                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="deleteMessage" class="fw-semibold">
                    Are you sure you want to delete this author?
                </p>
            </div>

            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-danger">
                        Delete
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    const deleteModal = document.getElementById('deleteModal');

    deleteModal.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        const authorId = button.getAttribute('data-id');
        const authorName = button.getAttribute('data-name');

        document.getElementById('deleteMessage').textContent =
            `Are you sure you want to delete the author "${authorName}"?`;

        const form = document.getElementById('deleteForm');
        form.action = `/Admin/Authors/Delete/${authorId}`;
    });
</script>
