@using BigBookLibrary.Extensions
@model BigBookLibrary.ViewModels.Books.BookDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">

    <div class="row">
        <div class="col-md-4">
            <img src="@Model.CoverImagePath"
                 class="img-fluid rounded shadow"
                 style="max-height: 500px; object-fit: cover;" />
        </div>

        <div class="col-md-8">
            <h2>@Model.Title</h2>
            <h5 class="text-muted">Author: @Model.AuthorName</h5>
            <p><strong>Genre:</strong> @Model.GenreName</p>

            <p class="mt-3">@Model.Description</p>

            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Borrow" asp-action="Borrow" asp-route-id="@Model.Id" class="btn btn-primary">
                    Borrow
                </a>
            }

            @if (TempData["BorrowSuccess"] != null)
            {
                <div class="alert alert-success mt-3">
                    @TempData["BorrowSuccess"]
                </div>
            }
        </div>
    </div>

    <hr class="my-5" />

    <h3>Reviews</h3>

    @if (User.Identity.IsAuthenticated)
    {
        <form method="post" asp-controller="Review" asp-action="Add" asp-route-bookId="@Model.Id">
            <div class="mb-3">
                <label class="form-label">Rating</label>
                <select name="Rating" class="form-select">
                    <option value="5">5 - Excellent</option>
                    <option value="4">4 - Very Good</option>
                    <option value="3">3 - Good</option>
                    <option value="2">2 - Poor</option>
                    <option value="1">1 - Bad</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Comment</label>
                <textarea name="Comment" class="form-control" rows="3"></textarea>
            </div>

            <button class="btn btn-success">Submit Review</button>
        </form>
    }

    @if (Model.Reviews.Any())
    {
        @foreach (var review in Model.Reviews)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <strong>@review.UserName</strong>
                    <span class="text-warning">@review.Rating ★</span>

                    <p>@review.Comment</p>
                    <small class="text-muted">@review.CreatedOn.ToShortDateString()</small>

                    @if (User.Identity.IsAuthenticated &&
                                (review.UserId == User.GetId() || User.IsInRole("Administrator")))
                    {
                        <form method="post" asp-controller="Review" asp-action="Delete"
                              asp-route-id="@review.Id" asp-route-bookId="@Model.Id">
                            <button class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No reviews yet.</p>
    }



</div>
